# API server
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true
LOG_LEVEL=INFO

# LLM (OpenAI-compatible endpoint)
OPENAI_API_KEY=your_openai_compatible_api_key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=60
OPENAI_WIRE_API=chat_completions
OPENAI_REASONING_EFFORT=
OPENAI_DISABLE_RESPONSE_STORAGE=false

# Embeddings (RAG)
SILICONFLOW_API_KEY=your_siliconflow_api_key
SILICONFLOW_BASE_URL=https://api.siliconflow.cn
SILICONFLOW_EMBEDDING_MODEL=BAAI/bge-m3

# Cover generation
VOLCENGINE_API_KEY=your_volcengine_api_key
VOLCENGINE_BASE_URL=https://ark.cn-beijing.volces.com
VOLCENGINE_MODEL=doubao-seedream-4-5-251128
COVER_STORAGE_DIR=./data/covers
COVER_MEDIA_URL_PREFIX=/media/covers

# GitHub trends (optional)
GITHUB_TOKEN=
GITHUB_TRENDING_TIMEZONE=Asia/Shanghai
GITHUB_TRENDING_DAILY_HOUR=9
GITHUB_TRENDING_DAILY_MINUTE=5

# Linux.do trends (optional, public Discourse JSON)
LINUXDO_BASE_URL=https://linux.do
LINUXDO_TRENDING_TIMEOUT_SECONDS=20
LINUXDO_TRENDING_TIMEZONE=Asia/Shanghai
LINUXDO_TRENDING_DEFAULT_LIMIT=20
LINUXDO_TRENDING_DAILY_HOUR=9
LINUXDO_TRENDING_DAILY_MINUTE=10
LINUXDO_REFRESH_COOLDOWN_SECONDS=90
LINUXDO_RSS_429_RETRIES=2
LINUXDO_RSS_429_DEFAULT_RETRY_AFTER_SECONDS=6
LINUXDO_RSS_429_JITTER_SECONDS=0.5
LINUXDO_SUMMARY_USE_LLM=true
LINUXDO_SUMMARY_LLM_TRIGGER_CHARS=500
LINUXDO_SUMMARY_LLM_TIMEOUT_SECONDS=8

# Xiaohongshu trends (optional, authorized 3rd-party provider)
# Minimal setup: keep only provider + MCP endpoint. Other knobs use code defaults.
XHS_TRENDS_PROVIDER=algovate_mcp
XHS_MCP_URL=http://127.0.0.1:3000/mcp

# Optional (only when provider=http_api)
# XHS_TRENDS_API_BASE_URL=
# XHS_TRENDS_API_KEY=

# Optional (only when MCP needs a custom browser executable)
# XHS_MCP_BROWSER_PATH=

# Optional (comment enrichment cooldown, default 1800s)
# XHS_TRENDS_COMMENT_ENRICHMENT_TTL_SECONDS=1800

# Optional (local MCP daemon helper script, does not affect app runtime parsing)
# XHS_MCP_NPX_PACKAGE=xhs-mcp@0.8.11
# XHS_MCP_PORT=3000
# XHS_ENABLE_LOGGING=false
# XHS_HEADLESS=true

# Observability
OBS_ENABLED=true
OBS_MODE=shadow
OBS_LOG_DIR=./data/observability
OBS_RETENTION_DAYS=14
OBS_TOKEN=
OBS_STRICT_DEV=true

# Database
DATABASE_URL=sqlite:///./data/acceptance_write_agent.db

# Legacy compatibility aliases (optional)
# MINIMAX_API_KEY=
# MINIMAX_BASE_URL=
# MINIMAX_MODEL=
